# Скопируйте в .env в этой папке. Не коммитьте .env.

# Ключ доступа к LiteLLM Proxy (тот же передаётся Open WebUI как OPENAI_API_KEY)
LITELLM_MASTER_KEY=replace-with-long-random-secret

# Секрет веб-интерфейса Open WebUI (обязателен для продакшена)
WEBUI_SECRET_KEY=replace-with-another-random-secret

WEBUI_URL=http://localhost:3000

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=paste-your-openrouter-key-here
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OR_SITE_URL=http://localhost:3000
OR_APP_NAME=GPTHub

# Фоновые задачи Open WebUI (заголовки и т.д.) — модель из LiteLLM
TASK_MODEL_EXTERNAL=gpt-hub-strong

# Память (Memories) в UI — по умолчанию true; выключить: ENABLE_MEMORIES=false
ENABLE_MEMORIES=true

# --- RAG: ваш BGE embedding (OpenAI-compatible /v1/embeddings) на хосте ---
# Из контейнера Open WebUI: host.docker.internal (см. extra_hosts в compose).
# Если сервис на другой машине (TailScale) — подставьте URL в локальный .env.
RAG_EMBEDDING_ENGINE=openai
RAG_OPENAI_API_BASE_URL=http://host.docker.internal:9001/v1
RAG_OPENAI_API_KEY=local-embedding
RAG_EMBEDDING_MODEL=BAAI/bge-m3

# --- RAG reranker: полный URL (POST /v1/rerank) ---
RAG_RERANKING_ENGINE=external
RAG_EXTERNAL_RERANKER_URL=http://host.docker.internal:9002/v1/rerank
RAG_EXTERNAL_RERANKER_API_KEY=

# Отключить внешний rerank: в .env задайте RAG_RERANKING_ENGINE= (пусто) и перезапустите webui

# --- ASR (Speech-to-Text): Open WebUI → OpenAI-compatible /v1/audio/transcriptions ---
# Базовый хост — из скилла remote-asr-service (LOCAL_AI_ASR_BASE_URL). В локальном .env задайте пару:
#   LOCAL_AI_ASR_BASE_URL=http://YOUR_ASR_HOST:8001
#   AUDIO_STT_OPENAI_API_BASE_URL=http://YOUR_ASR_HOST:8001/v1
# Часто с Tailscale контейнер Open WebUI достучится до 100.x на GPU-сервере; иначе — проброс ssh -L 8001:… и host.docker.internal:8001/v1.
AUDIO_STT_ENGINE=openai
AUDIO_STT_OPENAI_API_BASE_URL=http://host.docker.internal:8001/v1
AUDIO_STT_OPENAI_API_KEY=local-asr
AUDIO_STT_MODEL=cstr/whisper-large-v3-turbo-int8_float32
# Опционально: сузить MIME (по умолчанию в compose: audio/*,video/webm)
# AUDIO_STT_SUPPORTED_CONTENT_TYPES=audio/wav,audio/mpeg,audio/webm
# Длинные файлы: таймаут HTTP-клиента WebUI (сек), по умолчанию 300
# AIOHTTP_CLIENT_TIMEOUT=600

# --- Instruct LLM на GPU (:8002), OpenAI-compatible /v1 — алиас gpt-hub-turbo в LiteLLM ---
# Скилл remote-llm-service: LOCAL_AI_LLM_INSTRUCT_BASE_URL; для LiteLLM нужен суффикс /v1.
# Пример: LLM_INSTRUCT_API_BASE=http://YOUR_GPU_TAILSCALE_HOST:8002/v1
# Модель в litellm/config.yaml должна совпадать с GET .../v1/models (по умолчанию qwen3-coder-30b-a3b-awq).
LLM_INSTRUCT_API_BASE=
LLM_INSTRUCT_API_KEY=local-instruct

# MWS GPT — после смены model_list в litellm/config.yaml на MWS
MWS_GPT_API_BASE=https://api.example.invalid/v1
MWS_GPT_API_KEY=replace-with-mws-api-key

# --- Безопасность Open WebUI (см. docker-compose, PersistentConfig в доке) ---
# Публичное демо: закрыть саморегистрацию
# ENABLE_SIGNUP=false
# Чтобы env всегда побеждал сохранённые в БД настройки (UI не персистит изменения):
# ENABLE_PERSISTENT_CONFIG=false
# Новые пользователи ждут активации админом (если signup включён; по умолчанию в compose: pending)
# DEFAULT_USER_ROLE=pending
# Сложные пароли при регистрации
# ENABLE_PASSWORD_VALIDATION=true
# Первый запуск без ручной регистрации: создать админа (только пустая БД); signup тогда отключается автоматически
# WEBUI_ADMIN_EMAIL=admin@example.local
# WEBUI_ADMIN_PASSWORD=replace-strong-password
# WEBUI_ADMIN_NAME=Admin
