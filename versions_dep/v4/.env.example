# Скопируйте в .env. Секреты не коммитить.
# GPTHub v4 — OpenRouter Free Survival Engine (без LiteLLM и локального LLM).

ORCHESTRATOR_API_KEY=replace-with-long-random-string
OPENROUTER_API_KEY=replace-with-openrouter-key
WEBUI_SECRET_KEY=replace-with-webui-secret

# Несколько ключей для rotation (quota per key): key1:50,key2:1000
# OPENROUTER_KEYS=sk-or-v1-aaa:50,sk-or-v1-bbb:1000

# Публичный URL Open WebUI
# WEBUI_URL=https://chat.example.com
# OR_SITE_URL=https://chat.example.com

# Open WebUI: один публичный id
DEFAULT_MODELS=gpt-hub
DEFAULT_PINNED_MODELS=gpt-hub
TASK_MODEL_EXTERNAL=gpt-hub

# Оркестратор
AUTO_ROUTE_MODEL=true
CODE_ROUTE_PREFERENCE=openrouter
ORCHESTRATOR_OPENROUTER_FALLBACK=true
ORCHESTRATOR_FALLBACK_MAX_ATTEMPTS=8
OPENROUTER_TIMEOUT_SECONDS=600
OPENROUTER_RPM_LIMIT=20
OPENROUTER_KEY_COOLDOWN_SECONDS=14400
OPENROUTER_QUOTA_TIMEZONE=UTC

# При каждом старте оркестратора — опрос OpenRouter и актуализация free-моделей + fallback-цепочек
OPENROUTER_REFRESH_CATALOG_ON_STARTUP=true
OPENROUTER_CATALOG_PERSIST_ON_REFRESH=true
OPENROUTER_CATALOG_TEXT_LIMIT=4
OPENROUTER_CATALOG_VISION_LIMIT=5
# false = при ошибке опроса использовать packaged catalog (не падать)
OPENROUTER_CATALOG_FAIL_ON_REFRESH_ERROR=false
# Периодический re-fetch (0 = выключено)
# OPENROUTER_CATALOG_REFRESH_INTERVAL_HOURS=6

# Runtime health: ban slug после N×429
OPENROUTER_MODEL_BAN_AFTER_429=3
OPENROUTER_MODEL_BAN_TTL_SECONDS=3600

# Stream fallback (модели в цепочке при SSE)
ORCHESTRATOR_STREAM_FALLBACK_MAX_ATTEMPTS=3

# Async LLM curator (не блокирует readyz)
OPENROUTER_CURATOR_ENABLED=false
# OPENROUTER_CURATOR_MODEL=google/gemma-3-12b-it:free
# OPENROUTER_CURATOR_TIMEOUT=60

# Admin endpoint /v1/admin/catalog (по умолчанию = ORCHESTRATOR_API_KEY)
# ORCHESTRATOR_ADMIN_API_KEY=

# ORCHESTRATOR_MODELS_CATALOG=single_public
# ORCHESTRATOR_PUBLIC_MODEL_ID=gpt-hub
# FREE_MODELS_CATALOG_PATH=

# Обновление каталога free-моделей (из apps/orchestrator):
# uv run python -m gpthub_orchestrator.tools.list_free_models --write-catalog

# RAG (profile rag): COMPOSE_PROFILES=rag docker compose up -d
# BGE_EMBEDDING_UPSTREAM=http://host.docker.internal:9001

# ASR опционально (если есть Whisper endpoint)
# ORCHESTRATOR_ASR_BASE_URL=http://host.docker.internal:8001/v1

WEBUI_BANNERS='[{"id":"gpthub-credit","type":"info","content":"GPT-hub v4 · OpenRouter Free Survival Engine","dismissible":true,"timestamp":0}]'
