# Скопируйте в .env. Секреты не коммитить.
# Те же ключи, что и в v2_c2; не публикуйте реальные IP Tailscale.

LITELLM_MASTER_KEY=replace-with-long-random-string
OPENROUTER_API_KEY=replace-with-openrouter-key
WEBUI_SECRET_KEY=replace-with-webui-secret

# Публичный URL Open WebUI (должен совпадать с тем, что видит браузер: Tunnel / Funnel / VPS)
# WEBUI_URL=https://chat.example.com
# OpenRouter: базовый URL UI для статистики
# OR_SITE_URL=https://chat.example.com

# Публичное демо: закрыть свободную регистрацию
# ENABLE_SIGNUP=false

# --- Режим «ты админ, остальные сами регистрируются и сразу пользуются» ---
# ENABLE_SIGNUP=true          # уже так по умолчанию в compose
# DEFAULT_USER_ROLE=user      # важно: иначе по умолчанию pending — каждого надо одобрять в админке
# Закрепить себя админом при новом инстансе (опционально):
# WEBUI_ADMIN_EMAIL=you@example.com
# WEBUI_ADMIN_PASSWORD=strong-one-time-password
# После смены переменных: docker compose up -d --force-recreate open-webui
# Уже живой инстанс: Admin → Users — один admin, остальные user (env сам роли не понижает).
# Подробно: ../../docs/OPENWEBUI_ROLES.md

# Open WebUI: один публичный id (совпадает с ORCHESTRATOR_PUBLIC_MODEL_ID); реальные алиасы скрыты в UI
DEFAULT_MODELS=gpt-hub
DEFAULT_PINNED_MODELS=gpt-hub
# TASK_MODEL_EXTERNAL=gpt-hub

# Оркестратор: каталог моделей для GET /v1/models — single_public (одна модель) или all (все алиасы LiteLLM, отладка)
# ORCHESTRATOR_MODELS_CATALOG=single_public
# ORCHESTRATOR_PUBLIC_MODEL_ID=gpt-hub

# Open WebUI: все зарегистрированные пользователи видят те же модели, что и админ (иначе у user пустой dropdown)
# BYPASS_MODEL_ACCESS_CONTROL=false  # включите строгий RBAC и раздавайте модели группам в Admin Panel

# По умолчанию true: оркестратор подменяет model по classifier + model_roles.yaml. false — модель из UI
AUTO_ROUTE_MODEL=true

# Код/глубокий анализ: local = gpt-hub-turbo (:8002) первым; openrouter = только free OpenRouter
CODE_ROUTE_PREFERENCE=local

# При AUTO_ROUTE_MODEL=true: при 429/503 перебирать цепочку алиасов из model_roles.yaml (non-stream)
ORCHESTRATOR_LITELLM_FALLBACK=true
ORCHESTRATOR_FALLBACK_MAX_ATTEMPTS=4

# Таймаут httpx оркестратора к LiteLLM (сек): RAG/PDF + stream — лучше 600+
LITELLM_TIMEOUT_SECONDS=600

# Опционально: свой путь к model_roles.yaml (по умолчанию встроенный в пакет)
# MODEL_ROLES_PATH=
# Опционально: альтернативный role_prompts.yaml (фаза 0.5)
# ROLE_PROMPTS_PATH=

# Instruct для gpt-hub-turbo: OpenAI-compatible на GPU (Tailscale IP Linux, не localhost с Mac)
# LLM_INSTRUCT_API_BASE=http://100.x.x.x:8002/v1
# LLM_INSTRUCT_API_KEY=local-instruct

# MWS после Задачи
# MWS_GPT_API_BASE=
# MWS_GPT_API_KEY=

# RAG: Open WebUI → embedding-shim → BGE на хосте :9001 (shim добавляет поле embedding из dense_embedding)
RAG_OPENAI_API_BASE_URL=http://embedding-shim:8000/v1
RAG_OPENAI_API_KEY=local-embedding
RAG_EMBEDDING_MODEL=BAAI/bge-m3
BGE_EMBEDDING_UPSTREAM=http://host.docker.internal:9001

# ASR на GPU: с Mac Docker — URL по Tailscale (compose подставляет из .env)
# AUDIO_STT_OPENAI_API_BASE_URL=http://100.x.x.x:8001/v1
# AUDIO_STT_OPENAI_API_KEY=local-asr

# Rerank на Mac — по умолчанию compose: host.docker.internal:9002; иначе:
# RAG_EXTERNAL_RERANKER_URL=http://100.x.x.x:9002/v1/rerank

# --- Веб-поиск (Tavily) в чате Open WebUI ---
# В compose по умолчанию ENABLE_WEB_SEARCH=true; задайте ключ:
# TAVILY_API_KEY=tvly-your-key
# Отключить поиск: ENABLE_WEB_SEARCH=false
# WEB_SEARCH_ENGINE=tavily
# После правок: docker compose up -d --force-recreate open-webui
# При ENABLE_PERSISTENT_CONFIG=true настройки из Admin → Settings → Web Search могут перекрывать env.
# В чате часто нужно включить режим веб-поиска у сообщения (иконка), иначе модель отвечает без вызова Tavily.

# --- Оркестратор: canned приветствия (greeting_or_tiny без картинок) без вызова LiteLLM ---
# GREETING_CANNED_RESPONSE_ENABLED=true
# GREETING_CANNED_MESSAGE=Привет! Чем могу помочь?

# Last resort: вырезать известные преамбулы CoT из content только для non-stream (см. PROMPT_PRECEDENCE)
# ORCHESTRATOR_STRIP_KNOWN_COT_PREAMBLE=false

# --- Оркестратор: дата/время в system (ответы «который час», «какой сегодня день») ---
# INJECT_REQUEST_DATETIME=true
# ORCHESTRATOR_CLOCK_TZ=UTC
# ORCHESTRATOR_CLOCK_TZ=Europe/Moscow
