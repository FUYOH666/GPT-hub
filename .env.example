# Скопируйте в .env и задайте значения локально. Не коммитьте .env.

# --- LiteLLM Proxy ---
LITELLM_MASTER_KEY=your-litellm-master-key
LITELLM_SALT_KEY=your-litellm-salt-key

# --- MWS GPT (плейсхолдеры; точные имена — по документации MWS и Задаче 10.04) ---
MWS_GPT_API_KEY=your-mws-api-key
MWS_GPT_API_BASE=https://api.example.invalid

# --- Open WebUI ---
OPENAI_API_BASE_URL=http://litellm:4000
OPENAI_API_KEY=your-litellm-master-key

# --- Опционально: свой ASR (OpenAI-compatible) ---
# ASR_API_BASE=https://your-asr-endpoint.example
# ASR_API_KEY=

# --- Опционально: embeddings / rerank (OpenAI-compatible) ---
# EMBEDDING_API_BASE=
# EMBEDDING_API_KEY=
# RERANKER_API_BASE=

# --- Опционально: OpenRouter через LiteLLM (не хранить ключ в git) ---
# OPENROUTER_API_KEY=

# --- Публичный деплой: публичный URL приложения (для проверок и документации) ---
# PUBLIC_APP_URL=https://your-demo.example

# Полный стек Open WebUI + LiteLLM + guardrails: см. versions_dep/v2_c2/.env.example
